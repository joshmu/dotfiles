{
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint scripts/ --ignore-pattern 'node_modules'",
    "format": "oxfmt 'scripts/**/*.ts' --no-error-on-unmatched-pattern",
    "format:check": "oxfmt --check 'scripts/**/*.ts' --no-error-on-unmatched-pattern",
    "shellcheck": "git ls-files '*.sh' | xargs shellcheck",
    "bash32-compat": "git ls-files '*.sh' | xargs bash scripts/check-bash32-compat.sh",
    "validate": "bun run typecheck && bun run lint && bun run format:check && bun run shellcheck && bun run bash32-compat",
    "test": "bun test"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "typescript": "^6.0.2"
  }
}
