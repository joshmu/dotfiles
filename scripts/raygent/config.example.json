{
  "default": "work",
  "workspaces": {
    "work": {
      "path": "$WORK_DIR",
      "keywords": ["work", "project", "client"]
    },
    "personal": {
      "path": "~/code",
      "keywords": ["personal", "config", "dotfiles", "scripts"]
    },
    "side-project": {
      "path": "~/code/side-project",
      "keywords": ["side project", "hobby", "experiment"]
    },
    "review-tasks": {
      "path": "$WORK_DIR/repos",
      "keywords": ["review", "pr", "code review"],
      "exactKeywords": ["review-pr", "pr-review"],
      "tmuxSession": "review-tasks"
    }
  }
}
