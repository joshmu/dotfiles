{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "leading_diamond": "\u256d\u2500\ue0b6",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "foreground": "#cdd6f4",
          "background": "#45475a",
          "type": "os",
          "style": "diamond"
        },
        {
          "properties": {
            "home_icon": "~",
            "style": "unique"
          },
          "template": " \uf07c {{ .Path }} ",
          "foreground": "#89b4fa",
          "powerline_symbol": "\ue0b0",
          "background": "#313244",
          "type": "path",
          "style": "powerline"
        },
        {
          "properties": {
            "branch_icon": "\uf126 ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "#a6e3a1",
          "powerline_symbol": "\ue0b0",
          "background": "#181825",
          "type": "git",
          "style": "powerline",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#f9e2af{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f38ba8{{ end }}",
            "{{ if gt .Ahead 0 }}#89dceb{{ end }}",
            "{{ if gt .Behind 0 }}#fab387{{ end }}"
          ]
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "fetch_version": true
          },
          "template": " {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} \ue718 ",
          "foreground": "#a6e3a1",
          "powerline_symbol": "\ue0b2",
          "background": "#313244",
          "type": "node",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "fetch_version": true
          },
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} \ue627 ",
          "foreground": "#89dceb",
          "powerline_symbol": "\ue0b2",
          "background": "#181825",
          "type": "go",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "fetch_version": true
          },
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} \ue624 ",
          "foreground": "#cba6f7",
          "powerline_symbol": "\ue0b2",
          "background": "#313244",
          "type": "julia",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "display_mode": "files",
            "fetch_virtual_env": false
          },
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} \ue235 ",
          "foreground": "#f9e2af",
          "powerline_symbol": "\ue0b2",
          "background": "#181825",
          "type": "python",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          },
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} \ue791 ",
          "foreground": "#f38ba8",
          "powerline_symbol": "\ue0b2",
          "background": "#313244",
          "type": "ruby",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "display_mode": "files",
            "fetch_version": false
          },
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} \uf0e7",
          "foreground": "#fab387",
          "powerline_symbol": "\ue0b2",
          "background": "#181825",
          "type": "azfunc",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "display_default": false
          },
          "template": " {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} \ue7ad ",
          "powerline_symbol": "\ue0b2",
          "background": "#313244",
          "type": "aws",
          "style": "powerline",
          "foreground_templates": [
            "{{if contains \"default\" .Profile}}#fab387{{end}}",
            "{{if contains \"jan\" .Profile}}#f38ba8{{end}}"
          ],
          "invert_powerline": true
        },
        {
          "template": " \uf0ad ",
          "foreground": "#f9e2af",
          "powerline_symbol": "\ue0b2",
          "background": "#181825",
          "type": "root",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "template": " {{ .FormattedMs }} \uf252 ",
          "foreground": "#f9e2af",
          "powerline_symbol": "\ue0b2",
          "background": "#313244",
          "type": "executiontime",
          "style": "powerline",
          "invert_powerline": true
        },
        {
          "properties": {
            "always_enabled": true
          },
          "template": " {{ if gt .Code 0 }}{{ reason .Code }}{{ else }}✔{{ end }} ",
          "foreground": "#a6e3a1",
          "powerline_symbol": "\ue0b2",
          "background": "#181825",
          "type": "status",
          "style": "powerline",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#f38ba8{{ end }}"
          ],
          "invert_powerline": true
        },
        {
          "trailing_diamond": "\ue0b4\u2500\u256e",
          "template": " {{ .CurrentDate | date .Format }} \uf017 ",
          "foreground": "#cdd6f4",
          "background": "#45475a",
          "type": "time",
          "style": "diamond",
          "invert_powerline": true
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\u2570\u2500",
          "foreground": "#45475a",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": true
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "template": "\u2500\u256f",
          "foreground": "#45475a",
          "type": "text",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
